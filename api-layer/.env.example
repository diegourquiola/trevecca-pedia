# API Layer Configuration
# Copy this file to .env and update values as needed for local development

# Internal service URLs (for local development)
WIKI_SERVICE_URL=http://127.0.0.1:9454
SEARCH_SERVICE_URL=http://127.0.0.1:7724
AUTH_SERVICE_URL=http://127.0.0.1:8083

# Service port
API_LAYER_PORT=2745

# JWT secret - MUST match the JWT_SECRET set in the auth service
# The API layer validates tokens locally for protected wiki routes
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
